{
  "name": "@heartjs/heart",
  "version": "1.0.0-alpha.2.1",
  "main": "dist/index.js",
  "repository": "https://github.com/heartjs/heart.git",
  "bugs": "https://github.com/heartjs/heart/issues",
  "author": "Tony Pinkevych <tony@untimestudio.com>",
  "license": "MIT",
  "private": false,
  "description": "Lightweight isolated business logic processor for monolith projects built with event sourcing pattern in mind",
  "keywords": [
    "business logic",
    "ddd",
    "event sourcing",
    "cqrs",
    "nodejs"
  ],
  "files": [
    "dist",
    "index.js",
    "index.d.ts",
    "utils.js",
    "utils.d.ts"
  ],
  "devDependencies": {
    "@types/jest": "^26.0.19",
    "@types/ramda": "^0.27.34",
    "@types/uuid": "^8.3.0",
    "jest": "^26.6.3",
    "lerna": "^3.22.1",
    "ts-jest": "^26.4.4",
    "typescript": "^4.1.3"
  },
  "scripts": {
    "build": "rm -rf ./dist && tsc",
    "lint": "eslint ./src --fix --ext .js,.jsx,.ts,.tsx",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "predeploy": "yarn build && cp ../../README.md ./README.md",
    "deploy": "npm publish",
    "start": "tsc -w",
    "typecheck": "tsc"
  },
  "dependencies": {
    "ramda": "^0.27.1",
    "uuid": "^8.3.2"
  }
}
